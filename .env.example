# manban — Beispiel-Umgebung. Kopiere nach .env und passe die Werte an.
# .env NICHT einchecken (steht in .gitignore).
#
# ─────────────────────────────────────────────────────────────────────────────
# PRODUKTION (Hostinger, hinter Traefik) — siehe docs/deployment-hostinger.md.
# Der Prod-Stack startet mit:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# Dort terminiert Traefik das TLS für kanban.mwolff.org; MANBAN_DOMAIN/MANBAN_ACME_EMAIL
# (die lokalen Caddy-Werte) werden NICHT verwendet. Für Produktion mindestens setzen:
#   MANBAN_BASE_URL=https://kanban.mwolff.org
#   MANBAN_SESSION_SECRET=<openssl rand -hex 32>   (Deploy bricht sonst ab)
#   MANBAN_COOKIE_SECURE=true
#   POSTGRES_PASSWORD / MINIO_ROOT_USER / MINIO_ROOT_PASSWORD = starke Werte
#   MANBAN_MAIL_ENABLED=true + echte Strato-SMTP-Zugangsdaten
#   MANBAN_BOOTSTRAP_ADMIN_TOKEN=<Zufallswert> (nach dem ersten Admin wieder leeren)
#
# ⚠️  SONDERZEICHEN IN SECRETS: Docker Compose interpoliert `$` in .env-Werten.
#     Enthält ein Wert ein `$` (z. B. ein vorgegebenes SMTP-Passwort), muss JEDES
#     `$` als `$$` geschrieben werden — sonst wird der Wert stillschweigend
#     verstümmelt (Symptom: `WARN The "…" variable is not set`).
#     Beispiel: Passwort `ab$cd` → `ab$$cd` in der .env.
#     Für SELBST erzeugte Tokens `$`-freie Erzeugung bevorzugen: `openssl rand -hex 32`
#     (nur 0-9a-f) statt `-base64` — dann entfällt das Escaping ganz.
#     Kontrolle: `docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#                 config 2>&1 >/dev/null | grep -c "is not set"`  → muss 0 sein.
# ─────────────────────────────────────────────────────────────────────────────

# Öffentliche Domain (Caddy, nur lokal). Default localhost -> interne CA / self-signed TLS.
# In Produktion ungenutzt (Traefik terminiert TLS) — siehe Prod-Block oben.
MANBAN_DOMAIN=localhost
MANBAN_ACME_EMAIL=admin@example.com

# Öffentliche Basis-URL für Links in E-Mails (Verifikation). Hinter Caddy = https.
MANBAN_BASE_URL=https://localhost

# Secret zum Signieren der Session-Tokens.
# In PRODUKTION zwingend durch einen zufälligen 32+-Byte-Wert ersetzen, z. B.:
#   openssl rand -hex 32   (nur 0-9a-f, kein $-Escaping nötig — siehe Prod-Block oben)
MANBAN_SESSION_SECRET=dev-only-insecure-secret-change-me
# Session-Cookie nur über HTTPS ausliefern. Hinter TLS (Prod) true;
# nur für reines HTTP-Lokal ggf. auf false setzen.
MANBAN_COOKIE_SECURE=true

# Einmal-Token, um auf einer frischen Instanz den ersten Plattform-Admin zu erzeugen
# (Aufruf /admin/bootstrap). Leer = deaktiviert; greift nur, solange kein Admin existiert.
# Nach dem Bootstrap wieder leeren und manban-api neu erstellen.
MANBAN_BOOTSTRAP_ADMIN_TOKEN=

# Postgres
POSTGRES_DB=manban
POSTGRES_USER=manban
POSTGRES_PASSWORD=change-me

# MinIO (Objektspeicher für Anhänge, ab Issue B5)
MINIO_ROOT_USER=manban
MINIO_ROOT_PASSWORD=change-me-minio

# E-Mail-Versand (Verifikation, Passwort-Reset, Einladungen).
# false = kein SMTP nötig, Links werden nur geloggt. Für Produktion auf true setzen —
# erst dann greifen die SMTP-Zugangsdaten unten.
MANBAN_MAIL_ENABLED=false
# Absender-Adresse der System-Mails.
MANBAN_MAIL_FROM=info@mwolff.org

# SMTP-Zugang (Beispiel: Strato). Echtes Passwort NUR hier in der gitignorten .env eintragen.
MANBAN_SMTP_HOST=smtp.strato.de
# 587 = STARTTLS (empfohlen, Default). Alternative 465 = SSL/SMTPS:
#   MANBAN_SMTP_PORT=465 und MANBAN_SMTP_STARTTLS=false setzen.
MANBAN_SMTP_PORT=587
MANBAN_SMTP_USER=info@mwolff.org
MANBAN_SMTP_PASSWORD=change-me-smtp
# SMTP-Auth bzw. STARTTLS abschalten (beides Default true) — nur für lokale Mailcatcher nötig.
#MANBAN_SMTP_AUTH=false
#MANBAN_SMTP_STARTTLS=false
