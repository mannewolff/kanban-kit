# manban — Beispiel-Umgebung. Kopiere nach .env und passe die Werte an.
# .env NICHT einchecken (steht in .gitignore).

# Öffentliche Domain (Caddy). Default localhost -> interne CA / self-signed TLS.
# Für Produktion echte Domain eintragen, dann holt Caddy automatisch ein Let's-Encrypt-Zertifikat.
MANBAN_DOMAIN=localhost
MANBAN_ACME_EMAIL=admin@example.com

# Postgres
POSTGRES_DB=manban
POSTGRES_USER=manban
POSTGRES_PASSWORD=change-me

# MinIO (Objektspeicher für Anhänge, ab Issue B5)
MINIO_ROOT_USER=manban
MINIO_ROOT_PASSWORD=change-me-minio

# SMTP (E-Mail-Versand, ab Issue A1). Leer/1025 = lokaler Dev-Mailcatcher.
MANBAN_SMTP_HOST=
MANBAN_SMTP_PORT=1025
MANBAN_SMTP_USER=
MANBAN_SMTP_PASSWORD=
